# K8s overrides — loaded on top of .env.local during k8s image build.
# NEXT_PUBLIC_API_URL is baked into the JS bundle at build time.
#
# Empty string = relative URLs (/api/...) — works in any environment
# (Kind, GKE, any domain) without rebuilding the image.
# The apiClient uses ?? so empty string is respected (not treated as falsy).
NEXT_PUBLIC_API_URL=
